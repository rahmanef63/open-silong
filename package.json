{
  "name": "open-silong",
  "private": true,
  "version": "0.1.0",
  "description": "An open-source Notion-inspired workspace for teams and personal use.",
  "license": "MIT",
  "author": "Rahman Effendi",
  "homepage": "https://silong-os.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahmanef63/open-silong.git"
  },
  "bugs": {
    "url": "https://github.com/rahmanef63/open-silong/issues"
  },
  "keywords": [
    "notion-inspired",
    "notion-alternative",
    "workspace",
    "block-editor",
    "block-based",
    "wiki",
    "knowledge-base",
    "convex",
    "nextjs",
    "react",
    "self-hosted",
    "open-source"
  ],
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "build:auto": "if [ -n \"$CONVEX_DEPLOY_KEY\" ]; then node scripts/setup-auth.mjs && convex deploy --typecheck=disable --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL --cmd 'next build'; else next build; fi",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "sync:rr": "node scripts/sync-to-rr.mjs",
    "sync:rr:status": "node scripts/rr-sync-status.mjs",
    "sync:rr:doc": "node scripts/sync-to-rr.mjs --regen-doc"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.36.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "highlight.js": "^11.11.1",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.462.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "rahman-shared": "^0.2.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "recharts": "2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jose": "^6.2.3",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4"
  }
}
