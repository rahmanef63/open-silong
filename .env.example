# open-silong — environment variables
#
# Two lanes are supported (see DEPLOY.md):
#   1. Convex Cloud — only the NEXT_PUBLIC_* + NEXT_SERVER_ACTIONS keys
#      are needed; Convex Cloud sets the rest in its dashboard.
#   2. Self-hosted Docker — every section below needs a value.
#
# Copy to `.env.local` and fill in. Never commit `.env.local`.

# ─────────────────────────────────────────────────────────────────────
# Frontend (Next.js) — required for BOTH lanes
# ─────────────────────────────────────────────────────────────────────

# URL of the Convex backend (cloud project URL OR your self-hosted
# Traefik-fronted https://api.your-domain.com).
NEXT_PUBLIC_CONVEX_URL=https://api-silong.rahmanef.com

# Public site URL (used by sitemap, share links, OG images, auth
# cookie scope). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://silong.rahmanef.com

# Optional — surfaced in /api/health for monitoring + Sentry release
# tagging.
NEXT_PUBLIC_DEPLOYMENT_ID=

# Required — 32-byte hex secret for Next 16 server-actions cookie
# encryption. Rotate on incident.
#   openssl rand -hex 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────
# Convex self-hosted backend (docker-compose.yml) — Lane 2 only
# ─────────────────────────────────────────────────────────────────────

# Short slug identifying this deployment in Convex internals.
INSTANCE_NAME=open-silong

# Long random secret. Generate fresh per deploy.
#   openssl rand -hex 32
INSTANCE_SECRET=

# Public origin of the Convex backend (same value as
# NEXT_PUBLIC_CONVEX_URL above when you front the backend with TLS).
CONVEX_CLOUD_ORIGIN=https://api-silong.rahmanef.com
CONVEX_SITE_ORIGIN=https://api-silong.rahmanef.com

# Convex Auth — JWT signing keys. Generate via Convex Auth docs:
#   https://labs.convex.dev/auth/setup/manual
JWT_PRIVATE_KEY=
JWKS=

# Admin key used by `convex deploy` to push schema + functions to your
# self-hosted backend. Must match what the Docker container received.
#   openssl rand -hex 32
CONVEX_ADMIN_KEY=

# ─────────────────────────────────────────────────────────────────────
# Database — REQUIRED for self-hosted prod (Lane 2)
# (SQLite default is dev-only)
# ─────────────────────────────────────────────────────────────────────

POSTGRES_URL=postgres://user:password@host:5432/silong

# ─────────────────────────────────────────────────────────────────────
# Object storage — OPTIONAL (Lane 2). Convex defaults to local disk.
# ─────────────────────────────────────────────────────────────────────

S3_STORAGE_EXPORTS_BUCKET=
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=
S3_STORAGE_MODULES_BUCKET=
S3_STORAGE_FILES_BUCKET=
S3_STORAGE_SEARCH_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────
# Observability — optional
# ─────────────────────────────────────────────────────────────────────

DISABLE_METRICS_ENDPOINT=false
REDACT_LOGS_TO_CLIENT=true

# ─────────────────────────────────────────────────────────────────────
# Unsplash — cover picker "Unsplash" tab (set on BACKEND, not exposed)
# ─────────────────────────────────────────────────────────────────────
# Set on the Convex backend (NOT NEXT_PUBLIC_ — must stay server-side):
#   pnpm exec convex env set UNSPLASH_ACCESS_KEY <key>
# Without this the Unsplash tab returns "not configured" instead of crashing.
UNSPLASH_ACCESS_KEY=
