# open-silong — environment variables
#
# Two lanes are supported (see DEPLOY.md):
#   1. Convex Cloud — only the NEXT_PUBLIC_* + NEXT_SERVER_ACTIONS keys
#      are needed; Convex Cloud sets the rest in its dashboard.
#   2. Self-hosted Docker — every section below needs a value.
#
# Copy to `.env.local` and fill in. Never commit `.env.local`.

# ─────────────────────────────────────────────────────────────────────
# Frontend (Next.js) — required for BOTH lanes
# ─────────────────────────────────────────────────────────────────────

# URL of the Convex backend (cloud project URL OR your self-hosted
# Traefik-fronted https://api.your-domain.com).
NEXT_PUBLIC_CONVEX_URL=https://api-silong.rahmanef.com

# Public site URL (used by sitemap, share links, OG images, auth
# cookie scope). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://silong.rahmanef.com

# Optional — surfaced in /api/health for monitoring + Sentry release
# tagging.
NEXT_PUBLIC_DEPLOYMENT_ID=

# Required — 32-byte hex secret for Next 16 server-actions cookie
# encryption. Rotate on incident.
#   openssl rand -hex 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# MCP (Model Context Protocol) endpoint surfaced in /settings → MCP
# panel and at the public `.well-known/oauth-protected-resource` route.
# Self-hosters override to their `site-*` Convex origin.
NEXT_PUBLIC_MCP_URL=https://site-silong.rahmanef.com/mcp

# ─────────────────────────────────────────────────────────────────────
# Convex self-hosted backend (docker-compose.yml) — Lane 2 only
# ─────────────────────────────────────────────────────────────────────

# Short slug identifying this deployment in Convex internals.
INSTANCE_NAME=open-silong

# Long random secret. Generate fresh per deploy.
#   openssl rand -hex 32
INSTANCE_SECRET=

# Public origin of the Convex backend (same value as
# NEXT_PUBLIC_CONVEX_URL above when you front the backend with TLS).
CONVEX_CLOUD_ORIGIN=https://api-silong.rahmanef.com
CONVEX_SITE_ORIGIN=https://api-silong.rahmanef.com

# Convex Auth — JWT signing keys. Generate via Convex Auth docs:
#   https://labs.convex.dev/auth/setup/manual
JWT_PRIVATE_KEY=
JWKS=

# Admin key used by `convex deploy` to push schema + functions to your
# self-hosted backend. Must match what the Docker container received.
#   openssl rand -hex 32
CONVEX_ADMIN_KEY=

# ─────────────────────────────────────────────────────────────────────
# Database — REQUIRED for self-hosted prod (Lane 2)
# (SQLite default is dev-only)
# ─────────────────────────────────────────────────────────────────────

POSTGRES_URL=postgres://user:password@host:5432/silong

# ─────────────────────────────────────────────────────────────────────
# Object storage — OPTIONAL (Lane 2). Convex defaults to local disk.
# ─────────────────────────────────────────────────────────────────────

S3_STORAGE_EXPORTS_BUCKET=
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=
S3_STORAGE_MODULES_BUCKET=
S3_STORAGE_FILES_BUCKET=
S3_STORAGE_SEARCH_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────
# Observability — optional
# ─────────────────────────────────────────────────────────────────────

DISABLE_METRICS_ENDPOINT=false
REDACT_LOGS_TO_CLIENT=true

# ─────────────────────────────────────────────────────────────────────
# Unsplash — cover picker "Unsplash" tab (set on BACKEND, not exposed)
# ─────────────────────────────────────────────────────────────────────
# Set on the Convex backend (NOT NEXT_PUBLIC_ — must stay server-side):
#   pnpm exec convex env set UNSPLASH_ACCESS_KEY <key>
# Without this the Unsplash tab returns "not configured" instead of crashing.
UNSPLASH_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────
# Convex env (set with `pnpm exec convex env set <KEY> <value>`)
# ─────────────────────────────────────────────────────────────────────
# These are read by Convex functions only — DO NOT put them in
# `.env.local` for the frontend lane. Push them to your deployment with
# the convex CLI; the keys below document expected names and purposes.

# Site origin used by MCP well-known + OAuth metadata generators.
# Defaults to https://silong.rahmanef.com if unset (reference deploy).
#   pnpm exec convex env set SITE_URL https://your.domain
# SITE_URL=

# Admin bootstrap — first sign-in with this email auto-promotes to
# super-admin. Set BEFORE first sign-in. Comma-separated for the
# non-super variant. Leave unset if you'd rather promote manually via
# the admin UI after creating users.
#   pnpm exec convex env set SUPER_ADMIN_EMAIL you@example.com
#   pnpm exec convex env set ADMIN_BOOTSTRAP_EMAILS one@x.io,two@y.io
# SUPER_ADMIN_EMAIL=
# ADMIN_BOOTSTRAP_EMAILS=

# OpenRouter — AI chat / database AI-assist actions. Required for the
# AI surfaces; leave unset to disable them.
#   pnpm exec convex env set OPENROUTER_API_KEY sk-or-...
#   pnpm exec convex env set OPENROUTER_APP_NAME open-silong         # optional
#   pnpm exec convex env set OPENROUTER_REFERER https://your.domain  # optional
# OPENROUTER_API_KEY=
# OPENROUTER_APP_NAME=open-silong
# OPENROUTER_REFERER=https://silong.rahmanef.com

# AI key encryption — symmetric secret used to encrypt user-supplied
# AI API keys at rest in the `userAIKeys` table.
#   openssl rand -hex 32
#   pnpm exec convex env set AI_KEY_ENCRYPTION_SECRET <hex>
# AI_KEY_ENCRYPTION_SECRET=

# MCP authentication — bearer token expected by /mcp/v1 callers when
# OAuth is not in use. Per-user tokens (issued via Settings → MCP) take
# precedence; this env var is the fallback realm token.
#   pnpm exec convex env set MCP_API_KEY <random>
#   pnpm exec convex env set MCP_API_TOKEN <random>     # legacy alias
#   pnpm exec convex env set MCP_USER_ID <convex-user-id>  # owner of fallback creds
# MCP_API_KEY=
# MCP_API_TOKEN=
# MCP_USER_ID=

# Inbound email — optional webhook for "send email to your inbox"
# integrations (Postmark / Mailgun parse hooks). Skip if unused.
#   pnpm exec convex env set EMAIL_INBOUND_TOKEN <random>
#   pnpm exec convex env set EMAIL_ALLOWED_SENDERS a@x.io,b@y.io
#   pnpm exec convex env set EMAIL_TARGET_USER_ID <convex-user-id>
# EMAIL_INBOUND_TOKEN=
# EMAIL_ALLOWED_SENDERS=
# EMAIL_TARGET_USER_ID=

# First-run welcome seed — set to "1" to skip the demo pages inserted
# into a freshly-created personal workspace.
#   pnpm exec convex env set SILONG_DISABLE_SEED 1
# SILONG_DISABLE_SEED=
