# Frontend (Next.js)
NEXT_PUBLIC_CONVEX_URL=https://api-notion-page-clone.rahmanef.com
NEXT_PUBLIC_DEPLOYMENT_ID=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Convex self-hosted backend (docker-compose.yml)
INSTANCE_NAME=notion-page-clone
INSTANCE_SECRET=
CONVEX_CLOUD_ORIGIN=https://api-notion-page-clone.rahmanef.com
CONVEX_SITE_ORIGIN=https://api-notion-page-clone.rahmanef.com
JWT_PRIVATE_KEY=
JWKS=
CONVEX_ADMIN_KEY=

# Database — REQUIRED for prod (SQLite default is dev-only)
POSTGRES_URL=

# Object storage (optional — Convex defaults to local disk)
S3_STORAGE_EXPORTS_BUCKET=
S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=
S3_STORAGE_MODULES_BUCKET=
S3_STORAGE_FILES_BUCKET=
S3_STORAGE_SEARCH_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability
DISABLE_METRICS_ENDPOINT=false
REDACT_LOGS_TO_CLIENT=true

# Unsplash — cover picker "Unsplash" tab.
# Set on the Convex backend (NOT NEXT_PUBLIC_ — must stay server-side):
#   pnpm exec convex env set UNSPLASH_ACCESS_KEY <key>
# Without this the Unsplash tab returns "not configured" instead of crashing.
UNSPLASH_ACCESS_KEY=
