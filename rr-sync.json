    },
    {
      "from": "frontend/shared/lib/router",
      "to": "lib/shared/router"
    },
    {
      "from": "frontend/shared/lib/keyboard",
      "to": "lib/shared/keyboard"
    },
    {
      "from": "frontend/shared/lib/format",
      "to": "lib/shared/format"
    },
    {
      "from": "frontend/shared/lib/markdown",
      "to": "lib/shared/markdown"
    },
    {
      "from": "frontend/shared/lib/inlineMd",
      "to": "lib/shared/inlineMd"
    },
    {
      "from": "frontend/shared/lib",
      "to": "lib/shared/lib"
